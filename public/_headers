# 默认响应头
/*
  Permissions-Policy: interest-cohort=()
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; media-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'
  Cache-Control: public, max-age=0, must-revalidate

# 静态资源 - 长期缓存
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 截图资源（图片/视频）— 针对 /screenshots/* 的专属规则
/screenshots/*
  Access-Control-Allow-Origin: *
  X-Content-Type-Options: nosniff
  Cache-Control: public, max-age=604800

# 图片文件 - 中期缓存
/*.png
  Cache-Control: public, max-age=604800, must-revalidate

/*.jpg
  Cache-Control: public, max-age=604800, must-revalidate

/*.jpeg
  Cache-Control: public, max-age=604800, must-revalidate

/*.webp
  Cache-Control: public, max-age=604800, must-revalidate

/*.svg
  Cache-Control: public, max-age=604800, must-revalidate

# 视频文件 - 长期缓存
/*.mp4
  Cache-Control: public, max-age=2592000, must-revalidate
  Accept-Ranges: bytes

/*.webm
  Cache-Control: public, max-age=2592000, must-revalidate
  Accept-Ranges: bytes

/*.mov
  Cache-Control: public, max-age=2592000, must-revalidate
  Accept-Ranges: bytes

# 字体文件 - 长期缓存
/*.woff
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# JS/CSS 资源 - 长期缓存
/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Sitemap 短期缓存
/sitemap*.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=604800
