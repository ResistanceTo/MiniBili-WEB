---
interface Props {
  name?: string;
  url?: string;
  logo?: string;
  contactEmail?: string;
}

const siteBase = Astro.site?.href.replace(/\/$/, '') ?? 'https://minibili.zhaohe.org';

const {
  name = "MiniBili",
  url = siteBase,
  logo = `${siteBase}/MiniBili.png`,
  contactEmail = "me@zhaohe.org"
} = Astro.props;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": name,
  "url": url,
  "logo": logo,
  "sameAs": [
    "https://github.com/ResistanceTo/MiniBili-WEB",
    "https://t.me/MiniBiliGroup",
    "https://github.com/ResistanceTo"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": contactEmail,
    "contactType": "customer support"
  },
  "description": "免费、无广告、无跟踪器的 Apple 平台第三方哔哩哔哩客户端"
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
