---
import { AppPlatform, type ChangelogEntry, type ChangelogProps } from "config";
import { FiClock, FiPackage, FiStar, FiTool, FiTrendingUp } from "react-icons/fi";

const { items } = Astro.props as ChangelogProps;
const recentVersions = items.slice(0, 3);

const platformLabels: Record<string, string> = {
  [AppPlatform.iOS]: "iOS",
  [AppPlatform.macOS]: "macOS",
  [AppPlatform.tvOS]: "tvOS",
  [AppPlatform.watchOS]: "watchOS",
  [AppPlatform.visionOS]: "visionOS",
};

const normalizeItem = (item: string | ChangelogEntry) =>
  typeof item === "string" ? { text: item, images: [] } : { text: item.text, images: item.images ?? [] };
---

<section id="changelog" class="mb-16 scroll-mt-20">
  <div class="mb-6 flex items-center justify-between">
    <h2 class="text-2xl font-semibold text-gray-900 dark:text-white">最新更新</h2>
    <a href="/changelog" class="text-sm text-gray-600 transition-colors hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">
      查看全部 →
    </a>
  </div>

  <div class="space-y-3">
    {recentVersions.map(({ version, build, date, title, updates, platforms }) => (
      <article class="rounded-xl border border-gray-300 bg-white p-4 shadow-sm transition-shadow hover:shadow-md dark:border-white/10 dark:bg-white/[0.03]">
        <div class="mb-3 flex items-center justify-between">
          <div class="flex items-center gap-2.5">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-gray-100 dark:bg-white/[0.04]">
              <FiPackage className="h-4 w-4 text-gray-700 opacity-90 dark:text-white" />
            </div>
            <div class="flex flex-col">
              <div class="flex items-center gap-2">
                <h3 class="text-base font-medium text-gray-900 dark:text-white">{version}-{build}</h3>
                <div class="flex gap-1">
                  {(platforms ?? [AppPlatform.iOS]).map((platform) => (
                    <span class="rounded bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium text-gray-600 dark:bg-white/10 dark:text-gray-300">
                      {platformLabels[platform] ?? platform}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400">
            <FiClock className="h-3 w-3" />
            <span>{date}</span>
          </div>
        </div>

        {title && (
          <div class="mb-3 ml-[42px] rounded-lg border border-blue-200 bg-blue-50 p-2.5 dark:border-blue-800/30 dark:bg-blue-900/20">
            <p class="text-xs font-medium text-blue-900 dark:text-blue-300">{title}</p>
          </div>
        )}

        <ul class="ml-[42px] space-y-1.5">
          {updates.feature?.map((content) => {
            const item = normalizeItem(content);
            return (
              <li class="flex items-start gap-2 text-sm">
                <FiStar className="mt-0.5 h-3.5 w-3.5 flex-shrink-0 text-green-600 dark:text-green-400" />
                <div class="flex-1 leading-relaxed text-gray-600 dark:text-gray-400">
                  <span>{item.text}</span>
                  {item.images.length > 0 && (
                    <div class="mt-2 grid grid-cols-2 gap-2">
                      {item.images.map((imgPath, index) => (
                        <a href={imgPath} target="_blank" rel="noopener noreferrer">
                          <img
                            src={imgPath}
                            alt={`${item.text} - ${index + 1}`}
                            class="max-w-full cursor-pointer rounded-lg border border-gray-200 transition-opacity hover:opacity-90 dark:border-white/10"
                          />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </li>
            );
          })}

          {updates.improvement?.map((content) => {
            const item = normalizeItem(content);
            return (
              <li class="flex items-start gap-2 text-sm">
                <FiTrendingUp className="mt-0.5 h-3.5 w-3.5 flex-shrink-0 text-blue-600 dark:text-blue-400" />
                <div class="flex-1 leading-relaxed text-gray-600 dark:text-gray-400">
                  <span>{item.text}</span>
                  {item.images.length > 0 && (
                    <div class="mt-2 grid grid-cols-2 gap-2">
                      {item.images.map((imgPath, index) => (
                        <a href={imgPath} target="_blank" rel="noopener noreferrer">
                          <img
                            src={imgPath}
                            alt={`${item.text} - ${index + 1}`}
                            class="max-w-full cursor-pointer rounded-lg border border-gray-200 transition-opacity hover:opacity-90 dark:border-white/10"
                          />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </li>
            );
          })}

          {updates.bugfix?.map((content) => {
            const item = normalizeItem(content);
            return (
              <li class="flex items-start gap-2 text-sm">
                <FiTool className="mt-0.5 h-3.5 w-3.5 flex-shrink-0 text-orange-600 dark:text-orange-400" />
                <div class="flex-1 leading-relaxed text-gray-600 dark:text-gray-400">
                  <span>{item.text}</span>
                  {item.images.length > 0 && (
                    <div class="mt-2 grid grid-cols-2 gap-2">
                      {item.images.map((imgPath, index) => (
                        <a href={imgPath} target="_blank" rel="noopener noreferrer">
                          <img
                            src={imgPath}
                            alt={`${item.text} - ${index + 1}`}
                            class="max-w-full cursor-pointer rounded-lg border border-gray-200 transition-opacity hover:opacity-90 dark:border-white/10"
                          />
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </li>
            );
          })}
        </ul>
      </article>
    ))}
  </div>
</section>
