---
import { AppPlatform, type ChangelogEntry, type ChangelogProps } from "config";
import { FiClock, FiStar, FiTool, FiTrendingUp } from "react-icons/fi";

const { items } = Astro.props as ChangelogProps;
const recentVersions = items.slice(0, 3);

const platformLabels: Record<string, string> = {
  [AppPlatform.iOS]: "iOS",
  [AppPlatform.macOS]: "macOS",
  [AppPlatform.tvOS]: "tvOS",
  [AppPlatform.watchOS]: "watchOS",
  [AppPlatform.visionOS]: "visionOS",
};

const normalizeItem = (item: string | ChangelogEntry) =>
  typeof item === "string" ? { text: item, images: [] } : { text: item.text, images: item.images ?? [] };

const groups = [
  { key: "feature" as const, icon: FiStar, color: "text-emerald-500", label: "新功能" },
  { key: "improvement" as const, icon: FiTrendingUp, color: "text-sky-500", label: "优化" },
  { key: "bugfix" as const, icon: FiTool, color: "text-amber-500", label: "修复" },
];
---

<section id="changelog" class="scroll-mt-28 py-12 sm:py-20">
  <div class="mb-10 flex flex-col items-center gap-3 text-center sm:flex-row sm:items-end sm:justify-between sm:text-left">
    <div>
      <p class="mb-2 text-sm font-semibold tracking-[0.15em] text-brand">持续进化</p>
      <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">最新更新</h2>
    </div>
    <a href="/changelog/" class="glass inline-flex items-center gap-1.5 rounded-full px-4 py-2 text-sm font-medium text-ink transition-all hover:-translate-y-0.5">
      查看全部更新
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    {recentVersions.map(({ version, build, date, title, updates, platforms }) => (
      <article class="glass flex flex-col rounded-4xl p-6 transition-all duration-300 hover:-translate-y-1">
        <div class="mb-4 flex items-center justify-between">
          <div class="flex items-baseline gap-1.5">
            <span class="text-xl font-bold text-ink">{build}</span>
            <span class="text-sm text-ink-subtle">{version}</span>
          </div>
          <div class="flex gap-1">
            {(platforms ?? [AppPlatform.iOS]).map((platform) => (
              <span class="rounded-full bg-brand/10 px-2 py-0.5 text-[10px] font-semibold text-brand">
                {platformLabels[platform] ?? platform}
              </span>
            ))}
          </div>
        </div>

        <div class="mb-4 flex items-center gap-1.5 text-xs text-ink-subtle">
          <FiClock className="h-3 w-3" />
          <span>{date}</span>
        </div>

        {title && (
          <div class="mb-4 rounded-2xl border border-brand/20 bg-brand/[0.06] p-3">
            <p class="text-xs font-medium leading-relaxed text-ink">{title}</p>
          </div>
        )}

        <div class="space-y-3">
          {groups.map(({ key, icon: Icon, color, label }) => (
            updates[key] && updates[key]!.length > 0 && (
              <div>
                <div class="mb-1.5 flex items-center gap-1.5">
                  <Icon className={`h-3.5 w-3.5 ${color}`} />
                  <span class="text-xs font-semibold text-ink-muted">{label}</span>
                </div>
                <ul class="space-y-1">
                  {updates[key]!.map((content) => {
                    const item = normalizeItem(content);
                    return (
                      <li class="flex gap-1.5 text-sm leading-relaxed text-ink-muted">
                        <span class={`mt-1.5 h-1 w-1 flex-shrink-0 rounded-full ${color.replace("text-", "bg-")}`}></span>
                        <span>{item.text}</span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            )
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
