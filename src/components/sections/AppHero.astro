---
import type { AppHeroProps } from "config";
import { FiChevronDown } from "react-icons/fi";

const { storeLinks, logo } = Astro.props as AppHeroProps;

const platforms = [
  { key: "ios", name: "iOS", version: "26.0+", url: storeLinks.ios },
  { key: "macos", name: "macOS", version: "26.0+", url: storeLinks.macos },
  { key: "watchos", name: "watchOS", version: "11.0+", url: storeLinks.watchos },
  { key: "tvos", name: "tvOS", version: "18.0+", url: storeLinks.tvos },
  { key: "visionos", name: "visionOS", version: "2.0+", url: storeLinks.visionOS },
].filter((platform) => platform.url);

const badges = ["完全免费", "无广告", "无跟踪器"];
---

<section class="relative flex flex-col items-center pt-6 text-center md:pt-10">
  <!-- App 图标 + 后方柔光 -->
  <div class="relative mb-7">
    <div class="absolute inset-0 -z-10 scale-150 rounded-full bg-brand/25 blur-3xl" aria-hidden="true"></div>
    <img
      src={logo.src}
      alt="MiniBili 应用图标"
      class="h-24 w-24 rounded-[22px] shadow-glass-lg sm:h-28 sm:w-28"
      width="112"
      height="112"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-hairline/10 bg-hairline/[0.04] px-3 py-1.5 text-xs font-medium text-ink-muted">
    <span class="relative flex h-2 w-2">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand opacity-60"></span>
      <span class="relative inline-flex h-2 w-2 rounded-full bg-brand"></span>
    </span>
    全苹果平台 · SwiftUI 原生打造
  </div>

  <h1 class="max-w-3xl text-4xl font-bold leading-[1.1] tracking-tight text-ink sm:text-5xl lg:text-6xl">
    更纯粹的<span class="bg-gradient-to-r from-brand to-brand-600 bg-clip-text text-transparent">哔哩哔哩</span>体验
  </h1>

  <p class="mt-5 max-w-xl text-base leading-relaxed text-ink-muted sm:text-lg">
    免费、无广告、无跟踪器的第三方客户端。支持 iPhone、iPad、Apple Watch 与 Mac，所有数据只留在你的设备上。
  </p>

  <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
    {badges.map((badge) => (
      <span class="rounded-full border border-hairline/10 bg-hairline/[0.03] px-3 py-1 text-xs font-medium text-ink-muted">
        {badge}
      </span>
    ))}
  </div>

  <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
    <details class="group relative w-full sm:w-auto" data-auto-close>
      <summary class="flex cursor-pointer list-none items-center justify-center gap-2.5 rounded-2xl bg-brand px-6 py-3.5 font-semibold text-white shadow-[0_8px_28px_-6px_rgba(251,114,153,0.65)] transition-all hover:bg-brand-500 hover:shadow-[0_10px_32px_-6px_rgba(251,114,153,0.75)] active:scale-[0.98]">
        <img src="/TestFlight.png" alt="" class="h-6 w-6 rounded-md" />
        <span>通过 TestFlight 下载</span>
        <FiChevronDown className="h-4 w-4 transition-transform group-open:rotate-180" />
      </summary>

      <div class="glass-strong absolute left-1/2 top-full z-50 mt-2 w-60 -translate-x-1/2 overflow-hidden rounded-2xl p-1.5">
        {platforms.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between rounded-xl px-4 py-2.5 transition-colors hover:bg-hairline/[0.06]"
          >
            <span class="text-sm font-medium text-ink">{platform.name}</span>
            <span class="text-xs text-ink-subtle">{platform.version}</span>
          </a>
        ))}
      </div>
    </details>

    <a
      href="https://afdian.com/a/ResistanceTo"
      target="_blank"
      rel="noopener noreferrer"
      class="glass flex w-full items-center justify-center gap-2.5 rounded-2xl px-6 py-3.5 font-semibold text-ink transition-all hover:-translate-y-0.5 active:scale-[0.98] sm:w-auto"
    >
      <img src="/toubi.svg" alt="" class="h-6 w-6" />
      <span>爱发电赞助</span>
    </a>
  </div>
</section>

<style>
  summary::-webkit-details-marker { display: none; }
</style>

<script is:inline>
  document.addEventListener("click", (e) => {
    document.querySelectorAll("details[data-auto-close]").forEach((d) => {
      if (!d.contains(e.target)) d.removeAttribute("open");
    });
  });
</script>
</section>
