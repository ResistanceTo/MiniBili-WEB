---
import type { FeaturesProps } from "config";

const { items } = Astro.props as FeaturesProps;
---

<section id="features" class="scroll-mt-28 py-12 sm:py-20">
  <div class="mb-10 text-center">
    <p class="mb-2 text-sm font-semibold tracking-[0.15em] text-brand">为什么选择 MiniBili</p>
    <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">纯粹且免费</h2>
  </div>

  <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
    {items.map(({ icon: Icon, title, description }) => (
      <div class="glass group rounded-4xl p-7 transition-all duration-300 hover:-translate-y-1">
        <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-brand/10 text-brand transition-transform duration-300 group-hover:scale-110">
          <Icon className="h-7 w-7" />
        </div>
        <h3 class="mb-2 text-lg font-semibold text-ink">{title}</h3>
        <p class="text-sm leading-relaxed text-ink-muted">{description}</p>
      </div>
    ))}
  </div>
</section>
