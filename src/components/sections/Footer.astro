---
import { siteConfig } from "config";
import { FiClock, FiFileText, FiMap, FiShield } from "react-icons/fi";

const legalLinks = [
  { href: "/privacy/", icon: FiShield, text: "隐私" },
  { href: "/terms/", icon: FiFileText, text: "条款" },
  { href: "/changelog/", icon: FiClock, text: "日志" },
  { href: "/roadmap/", icon: FiMap, text: "路线" },
];
---

<footer class="relative z-10 mt-8 px-4 pb-6 sm:px-6">
  <div class="glass mx-auto max-w-[1120px] rounded-4xl p-6 sm:p-8">
    <div class="flex flex-col gap-8">
      <div class="flex flex-col items-start justify-between gap-6 sm:flex-row">
        <div class="flex max-w-md flex-col gap-3">
          <div class="flex items-center gap-2.5">
            <img src="/favicon-512.png" alt="MiniBili Logo" class="h-7 w-7 rounded-lg shadow-sm" />
            <span class="text-lg font-semibold text-ink">MiniBili</span>
          </div>
          <p class="text-sm leading-relaxed text-ink-muted">{siteConfig.description}</p>
          <p class="text-xs leading-relaxed text-ink-subtle">
            非官方第三方客户端，与哔哩哔哩官方无关，仅供学习和个人使用。
          </p>
        </div>

        <div class="flex flex-col items-start gap-4 sm:items-end">
          <div class="flex items-center gap-2">
            {siteConfig.socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex h-9 w-9 items-center justify-center rounded-xl border border-hairline/10 bg-hairline/[0.04] text-ink-muted transition-colors hover:bg-hairline/[0.08] hover:text-ink"
                aria-label={link.label}
                title={link.label}
              >
                <link.icon className="h-4 w-4" />
              </a>
            ))}
          </div>
          <nav class="flex flex-wrap items-center gap-x-5 gap-y-2" aria-label="页脚导航">
            {legalLinks.map(({ href, icon: Icon, text }) => (
              <a href={href} class="flex items-center gap-1.5 text-sm text-ink-muted transition-colors hover:text-ink">
                <Icon className="h-3.5 w-3.5" />
                <span>{text}</span>
              </a>
            ))}
          </nav>
        </div>
      </div>

      <div class="border-t border-hairline/10 pt-5 text-center text-xs text-ink-subtle sm:text-left">
        &copy; {new Date().getFullYear()} MiniBili · Made with ❤️ by ResistanceTo
      </div>
    </div>
  </div>
</footer>
