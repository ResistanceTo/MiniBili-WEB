---
import type { FAQProps } from "config";

const { items } = Astro.props as FAQProps;
---

<section id="faq" class="scroll-mt-28 py-12 sm:py-20">
  <div class="mb-10 text-center">
    <p class="mb-2 text-sm font-semibold tracking-[0.15em] text-brand">还有疑问</p>
    <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">常见问题</h2>
  </div>

  <div class="mx-auto max-w-3xl space-y-3">
    {items.map((item) => (
      <div class="glass overflow-hidden rounded-3xl">
        <details class="group">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 sm:p-6">
            <h3 class="font-semibold text-ink">{item.question}</h3>
            <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-hairline/[0.06] text-ink-muted transition-transform group-open:rotate-180">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </summary>
          <div class="border-t border-hairline/10 px-5 pb-5 pt-4 sm:px-6 sm:pb-6">
            <p class="leading-relaxed text-ink-muted">{item.answer}</p>
          </div>
        </details>
      </div>
    ))}
  </div>
</section>

<style>
  summary::-webkit-details-marker { display: none; }

  @keyframes faq-reveal {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  details[open] > div { animation: faq-reveal 0.2s ease forwards; }
</style>
