---
const themes = [
  { key: "light", label: "浅色", icon: "sun" },
  { key: "dark", label: "深色", icon: "moon" },
  { key: "system", label: "跟随系统", icon: "monitor" },
];
---

<div
  class="flex items-center rounded-lg border border-gray-300 bg-gray-200/80 p-1 shadow-sm dark:border-white/10 dark:bg-white/[0.03]"
  data-theme-toggle
>
  {themes.map(({ key, label, icon }) => (
    <button
      type="button"
      class="theme-toggle-button relative rounded-md p-2 text-sm font-medium text-gray-600 transition-colors hover:text-gray-800 dark:text-white/60 dark:hover:text-white"
      data-theme-option
      data-theme={key}
      title={label}
      aria-label={`切换到${label}主题`}
    >
      <span class="pointer-events-none absolute inset-0 rounded-md border border-transparent"></span>
      {icon === "sun" && (
        <svg class="relative z-10 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
      )}
      {icon === "moon" && (
        <svg class="relative z-10 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3c0 4.97 4.03 9 9 9 .27 0 .53-.01.79-.03"></path>
        </svg>
      )}
      {icon === "monitor" && (
        <svg class="relative z-10 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="3" width="20" height="14" rx="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
      )}
    </button>
  ))}
</div>

<script is:inline>
  const themeStorageKey = "theme";

  const applyTheme = (theme) => {
    const root = document.documentElement;
    root.classList.remove("light", "dark");

    if (theme === "system") {
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      root.classList.add(prefersDark ? "dark" : "light");
      return;
    }

    root.classList.add(theme);
  };

  const syncThemeButtons = (theme) => {
    document.querySelectorAll("[data-theme-toggle]").forEach((toggle) => {
      toggle.querySelectorAll("[data-theme-option]").forEach((button) => {
        const isActive = button.getAttribute("data-theme") === theme;
        button.classList.toggle("text-gray-900", isActive);
        button.classList.toggle("dark:text-white", isActive);
        button.classList.toggle("text-gray-600", !isActive);
        button.classList.toggle("dark:text-white/60", !isActive);

        const indicator = button.firstElementChild;
        indicator?.classList.toggle("bg-white", isActive);
        indicator?.classList.toggle("dark:bg-white/10", isActive);
        indicator?.classList.toggle("shadow-sm", isActive);
        indicator?.classList.toggle("border-gray-300/60", isActive);
        indicator?.classList.toggle("dark:border-white/5", isActive);
      });
    });
  };

  const getSavedTheme = () => localStorage.getItem(themeStorageKey) || "system";

  const initThemeToggles = () => {
    const savedTheme = getSavedTheme();
    applyTheme(savedTheme);
    syncThemeButtons(savedTheme);

    document
      .querySelectorAll("[data-theme-toggle]:not([data-theme-toggle-bound])")
      .forEach((toggle) => {
        toggle.setAttribute("data-theme-toggle-bound", "true");
        toggle.querySelectorAll("[data-theme-option]").forEach((button) => {
          button.addEventListener("click", () => {
            const nextTheme = button.getAttribute("data-theme") || "system";
            localStorage.setItem(themeStorageKey, nextTheme);
            applyTheme(nextTheme);
            syncThemeButtons(nextTheme);
          });
        });
      });
  };

  if (!window.__minibiliThemeListenerBound) {
    window.__minibiliThemeListenerBound = true;
    window
      .matchMedia("(prefers-color-scheme: dark)")
      .addEventListener("change", () => {
        if (getSavedTheme() === "system") {
          applyTheme("system");
          syncThemeButtons("system");
        }
      });
  }

  initThemeToggles();
</script>

<style>
  .theme-toggle-button:active {
    transform: scale(0.95);
  }
</style>
