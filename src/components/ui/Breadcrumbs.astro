---
import type { BreadcrumbsProps } from "config";
import { FiChevronRight, FiHome } from "react-icons/fi";

const { items } = Astro.props as BreadcrumbsProps;
---

<nav aria-label="面包屑导航" class="mb-8 flex items-center gap-1.5 text-sm text-ink-subtle">
  <a href="/" class="-ml-2 rounded-lg p-2 transition-colors hover:text-ink" aria-label="返回首页">
    <FiHome className="h-4 w-4" />
  </a>
  {items.map(({ label, href }) => (
    <div class="flex items-center gap-1.5">
      <FiChevronRight className="h-4 w-4 text-ink-subtle/60" />
      {href ? (
        <a href={href} class="transition-colors hover:text-ink">{label}</a>
      ) : (
        <span aria-current="page" class="font-medium text-ink">{label}</span>
      )}
    </div>
  ))}
</nav>
