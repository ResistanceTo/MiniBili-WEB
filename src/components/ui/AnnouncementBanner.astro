---
interface Props {
  message: string | string[];
  type?: "warning" | "info" | "success";
  dismissible?: boolean;
  show?: boolean;
}

const {
  message,
  type = "warning",
  dismissible = true,
  show = true,
} = Astro.props as Props;

if (!show || !message) {
  return;
}

const messageLines = (Array.isArray(message) ? message : message.split(/\r?\n/))
  .map((line) => line.trim())
  .filter(Boolean);

if (messageLines.length === 0) {
  return;
}

const typeStyles = {
  warning: {
    accent: "bg-amber-400",
    text: "text-ink",
    iconColor: "text-ink-subtle hover:text-ink",
  },
  info: {
    accent: "bg-sky-400",
    text: "text-ink",
    iconColor: "text-ink-subtle hover:text-ink",
  },
  success: {
    accent: "bg-brand",
    text: "text-ink",
    iconColor: "text-ink-subtle hover:text-ink",
  },
}[type];

const dismissKey = `announcement:${messageLines.join("\n")}`;
---

<div
  class="glass mb-8 overflow-hidden rounded-3xl p-4 sm:p-5"
  data-announcement
  data-dismiss-key={dismissKey}
>
  <div class="flex items-start gap-3.5">
    <span class:list={["w-1 flex-shrink-0 self-stretch rounded-full", typeStyles.accent]}></span>
    <div class="flex-1">
      <div class:list={["space-y-1 text-sm font-medium leading-relaxed", typeStyles.text]}>
        {messageLines.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    </div>
    {dismissible && (
      <button
        type="button"
        class:list={[
          "flex-shrink-0 transition-opacity hover:opacity-70",
          typeStyles.iconColor,
        ]}
        aria-label="关闭公告"
        data-announcement-close
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    )}
  </div>
</div>

{dismissible && (
  <script is:inline>
    document
      .querySelectorAll("[data-announcement]:not([data-announcement-bound])")
      .forEach((banner) => {
        banner.setAttribute("data-announcement-bound", "true");
        const dismissKey = banner.getAttribute("data-dismiss-key");
        const closeButton = banner.querySelector("[data-announcement-close]");

        if (dismissKey && localStorage.getItem(dismissKey) === "hidden") {
          banner.remove();
          return;
        }

        closeButton?.addEventListener("click", () => {
          if (dismissKey) {
            localStorage.setItem(dismissKey, "hidden");
          }
          banner.remove();
        });
      });
  </script>
)}
