---
interface Props {
  message: string;
  type?: "warning" | "info" | "success";
  dismissible?: boolean;
  show?: boolean;
}

const {
  message,
  type = "warning",
  dismissible = true,
  show = true,
} = Astro.props as Props;

if (!show || !message) {
  return;
}

const typeStyles = {
  warning: {
    bg: "bg-yellow-50 dark:bg-yellow-900/20",
    border: "border-yellow-200 dark:border-yellow-800/50",
    text: "text-yellow-800 dark:text-yellow-200",
    iconColor: "text-yellow-600 dark:text-yellow-400",
  },
  info: {
    bg: "bg-blue-50 dark:bg-blue-900/20",
    border: "border-blue-200 dark:border-blue-800/50",
    text: "text-blue-800 dark:text-blue-200",
    iconColor: "text-blue-600 dark:text-blue-400",
  },
  success: {
    bg: "bg-green-50 dark:bg-green-900/20",
    border: "border-green-200 dark:border-green-800/50",
    text: "text-green-800 dark:text-green-200",
    iconColor: "text-green-600 dark:text-green-400",
  },
}[type];

const dismissKey = `announcement:${message}`;
---

<div
  class:list={[
    "mb-6 rounded-lg border p-4 shadow-sm",
    typeStyles.bg,
    typeStyles.border,
  ]}
  data-announcement
  data-dismiss-key={dismissKey}
>
  <div class="flex items-start gap-3">
    <div class="flex-1">
      <p class:list={["text-sm font-medium leading-relaxed", typeStyles.text]}>
        {message}
      </p>
    </div>
    {dismissible && (
      <button
        type="button"
        class:list={[
          "flex-shrink-0 transition-opacity hover:opacity-70",
          typeStyles.iconColor,
        ]}
        aria-label="关闭公告"
        data-announcement-close
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    )}
  </div>
</div>

{dismissible && (
  <script is:inline>
    document
      .querySelectorAll("[data-announcement]:not([data-announcement-bound])")
      .forEach((banner) => {
        banner.setAttribute("data-announcement-bound", "true");
        const dismissKey = banner.getAttribute("data-dismiss-key");
        const closeButton = banner.querySelector("[data-announcement-close]");

        if (dismissKey && localStorage.getItem(dismissKey) === "hidden") {
          banner.remove();
          return;
        }

        closeButton?.addEventListener("click", () => {
          if (dismissKey) {
            localStorage.setItem(dismissKey, "hidden");
          }
          banner.remove();
        });
      });
  </script>
)}
