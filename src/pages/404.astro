---
import Layout from "@layouts/Layout.astro";
import { FiArrowLeft } from "react-icons/fi";
---

<Layout title="404 页面未找到 - MiniBili iOS哔哩哔哩客户端" description="抱歉，你访问的页面不存在" showFooter={false}>
  <main class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <h1 class="text-9xl font-bold text-gray-900 dark:text-white/90">404</h1>
      <h2 class="mt-8 text-xl font-medium text-gray-900 dark:text-white">页面不存在</h2>
      <p class="mt-4 text-gray-600 dark:text-gray-400">你访问的页面可能已被移动、删除，或链接地址有误。</p>
      <a href="/" class="mt-8 inline-flex items-center gap-3 rounded-xl border border-gray-300 dark:border-white/10 bg-white dark:bg-white/[0.04] px-5 py-3 hover:bg-gray-50 dark:hover:bg-white/[0.08]">
        <FiArrowLeft className="h-5 w-5 text-gray-600 dark:text-gray-300" />
        <span class="font-medium text-gray-900 dark:text-white">返回首页</span>
      </a>
    </div>
  </main>
</Layout>
