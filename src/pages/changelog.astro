---
import BackToTop from "@components/ui/BackToTop.astro";
import Breadcrumbs from "@components/ui/Breadcrumbs.astro";
import ChangelogFull from "@components/sections/ChangelogFull";
import BreadcrumbSchema from "@components/seo/BreadcrumbSchema.astro";
import Layout from "@layouts/Layout.astro";
import { changelog } from "../config/changelog";

const siteBase = Astro.site?.href ?? 'https://minibili.zhaohe.org/';
const breadcrumbItems = [
  { name: "首页", url: siteBase },
  { name: "更新日志", url: `${siteBase}changelog/` }
];
---

<Layout
  title="MiniBili 更新日志"
  description="查看 MiniBili 的所有版本更新记录，包括新功能、改进和问题修复"
>
  <BreadcrumbSchema items={breadcrumbItems} slot="head" />
  <main class="min-h-screen max-w-3xl mx-auto px-4 py-8">
    <Breadcrumbs items={[{ label: "更新日志" }]} />
    <ChangelogFull items={changelog} client:idle />
  </main>
  <BackToTop />
</Layout>
